# Single VPS deployment example
# For the current repository, SQLite is the simplest production choice on one server.
DATABASE_URL="file:/var/www/blog/shared/prisma/prod.db"

# Auth / Site URL
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# App
APP_URL="https://your-domain.com"
NODE_ENV="production"
