# Single VPS deployment example
# For the current repository, SQLite is the simplest production choice on one server.
DATABASE_URL="file:/var/www/blog/shared/prisma/prod.db"

# Auth / Site URL
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Admin (required for production seeding)
ADMIN_EMAIL="admin@troy.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Admin"

# App
APP_URL="https://your-domain.com"
NODE_ENV="production"

# Cloudflare R2 (direct upload + public delivery)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
